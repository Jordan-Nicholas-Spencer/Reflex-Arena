  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: f4688fdb7df04437aeb418b961361dc5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Unity.TextMeshPro::TMPro.TextMeshProUGUI
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "HOW TO PLAY \u2014 REFLEX ARENA\n\nOBJECTIVE:\nTargets appear on screen.
    Click them as fast as possible.\nEach target you hit scores 1 point. Most points
    wins the round.\nFirst to 3 round wins takes the match (best of 5).\n\nCONTROLS:\n-
    Left Click \u2014 Shoot (costs 1 bullet)\n- Right Click \u2014 Reload\n- Spacebar
    \u2014 Jam opponent's gun (once per match)\n- Left Shift \u2014 Throw pocket
    sand at opponent (once per match)\n\nAMMO:\nYou have 6 bullets. Shown as white
    bars at the bottom.\nIf you click with 0 bullets, you auto-reload.\nReloading
    fills bullets.\nIf you click during reload, reload stops and you fire if you
    have ammo.\n\nGUN JAM (Spacebar):\nPress Space once per match to jam your opponent's
    gun.\nThey must click to clear it.\nYour available jam is shown as a red circle
    near your ammo.\n\nPOCKET SAND (Shift):\nPress Shift once per match to throw
    sand on opponent's screen.\nThree splotches appear and fade over time.\nYour
    available sand is shown as a tan circle near your ammo.\n\nROUNDS:\nEach round
    spawns 10-15 targets simultaneously.\nA countdown timer shows how long targets
    remain.\nBetween rounds, a 3-second countdown prepares you.\nScoreboard displays
    between rounds.\n\nMULTIPLAYER:\nEach player sees their own targets in identical
    positions.\nShooting YOUR targets does not affect your opponent's screen.\nYour
    score is how many YOU clicked before time runs out."
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
  m_sharedMaterial: {fileID: 2180264, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
